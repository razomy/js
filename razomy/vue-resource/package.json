    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.32"
  },
  "engines": {
    "node": ">=18"
  },
  "exports": {
    "./package.json": "./package.json",
    "./specifications/*": "./specifications/*",
    "./src": {
      "default": {
        "default": "./src/index.ts",
        "types": "./src/index.ts"
      },
      "import": {
        "default": "./src/index.ts",
        "types": "./src/index.ts"
      },
      "require": {
        "default": "./src/index.ts",
        "types": "./src/index.ts"
      }
    }
  },
  "files": [
    "*"
  ],
  "homepage": "https://github.com/razomy/js/tree/main/razomy/vue-resource#readme",
  "keywords": [
    "razomy",
    "vue",
    "resource"
  ],
  "license": "MIT",
  "main": "./index.ts",
  "module": "./index.ts",
  "name": "@razomy/vue-resource",
  "peerDependencies": {
    "@razomy/array": "*",
    "@razomy/dict": "*",
    "@razomy/razomy": "*",
    "@razomy/server": "*",
    "vue": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "directory": "razomy/vue-resource",
    "type": "git",
    "url": "git+https://github.com/razomy/js.git"
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm,cjs --dts",
    "dev": "tsdown src/index.ts --watch",
    "prepublishOnly": "npm run build"
  },
  "sideEffects": false,
  "type": "module",
  "types": "./index.ts",
  "typesVersions": {
    "*": {
      ".": [
        "./index.ts"
      ]
    }
