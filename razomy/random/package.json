  "dependencies": {},
  "description": "Utility functions for safely generating random numbers, strings, and arbitrary values",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "default": {
        "default": "./index.ts",
        "types": "./index.ts"
      },
      "import": {
        "default": "./index.ts",
        "types": "./index.ts"
      },
      "require": {
        "default": "./index.ts",
        "types": "./index.ts"
      }
    },
    "./package.json": "./package.json",
    "./specifications/*": "./specifications/*"
  },
  "files": [
    "*"
  ],
  "homepage": "https://github.com/razomy/js/tree/main/razomy/random#readme",
  "keywords": [
    "razomy",
    "random",
    "createCssGradient",
    "createDate",
    "createFloatRange",
    "createFloat",
    "createGuid",
    "createInt",
    "createIpv4",
    "createLightHexColor",
    "createLorem",
    "createMac",
    "createPassword",
    "createPinCode",
    "createRecoveryKeys",
    "createString",
    "createUuid",
    "isYesOrNo",
    "pickItem",
    "rollDice",
    "shuffleArray",
    "splitIntoGroups"
  ],
  "license": "MIT",
  "main": "./index.ts",
  "module": "./index.ts",
  "name": "@razomy/random",
  "peerDependencies": {},
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "directory": "razomy/random",
    "type": "git",
    "url": "git+https://github.com/razomy/js.git"
  },
  "scripts": {
    "build": "tsdown index.ts --format esm,cjs --dts",
    "dev": "tsdown index.ts --watch",
    "prepublishOnly": "npm run build"
  },
  "sideEffects": false,
  "type": "module",
  "types": "./index.ts",
  "typesVersions": {
    "*": {
      ".": [
        "./index.ts"
      ]
    }
  },
  "version": "0.0.1-alpha.7"
}
