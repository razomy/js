        "default": "./index.ts",
        "types": "./index.ts"
      },
      "require": {
        "default": "./index.ts",
        "types": "./index.ts"
      }
    },
    "./package.json": "./package.json",
    "./specifications.json": "./specifications.json"
  },
  "files": [
    "*"
  ],
  "homepage": "https://github.com/razomy/js/tree/main/razomy/json#readme",
  "keywords": [
    "razomy",
    "json",
    "getDetailedDiff",
    "getValueFromDiff",
    "isObject",
    "jsonToObject",
    "jsonToString",
    "sort",
    "stringToJson"
  ],
  "license": "MIT",
  "main": "./index.ts",
  "module": "./index.ts",
  "name": "@razomy/json",
  "peerDependencies": {
    "@razomy/abstracts": "*",
    "@razomy/array": "*",
    "@razomy/context": "*",
