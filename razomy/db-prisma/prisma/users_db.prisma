model User {
  userId String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // --- Связи ---
  userProfile UserProfile?
  userAuth    UserAuth?
  events      AuthEvent[]

  @@schema("users_db")
}

model UserProfile {
  profileId String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String @unique @db.Uuid

  name   String?
  avatar String?

  // Здесь можно хранить текущий основной email для рассылок (не для входа)
  contactEmail String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@schema("users_db")
}
