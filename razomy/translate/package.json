      }
    },
    "./en": {
      "default": {
        "default": "./en/index.ts",
        "types": "./en/index.ts"
      },
      "import": {
        "default": "./en/index.ts",
        "types": "./en/index.ts"
      },
      "require": {
        "default": "./en/index.ts",
        "types": "./en/index.ts"
      }
    },
    "./fr": {
      "default": {
        "default": "./fr/index.ts",
        "types": "./fr/index.ts"
      },
      "import": {
        "default": "./fr/index.ts",
