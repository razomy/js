        "types": "./index.node.ts"
      },
      "require": {
        "default": "./index.ts",
        "types": "./index.ts"
      },
      "vue": {
        "import": "./index.browser.ts",
        "require": "./index.browser.ts",
        "types": "./index.browser.ts"
      }
