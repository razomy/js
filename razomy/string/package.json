    "countOccurrences",
    "countSpaceMarginByArray",
    "countSpaceMargin",
    "countString",
    "create",
    "escapeByString",
    "getSimilar",
    "getWords",
    "indentLines",
    "isEndsWithAny",
    "isEndsWith",
    "isNullOrEmpty",
    "isStartsWith",
    "isString",
    "isStringsAnyIndex",
    "join",
    "lastIndex",
    "levenshteinDistance",
    "merge",
    "nextMarginIndex",
    "padEnd",
    "padStart",
    "prefixLines",
    "removeIndex",
    "repeat",
    "replace",
    "similarity",
    "splitLines",
    "split",
    "stringsAnyIndex",
    "stripTags",
    "takeAfter",
    "takeBefore",
    "takeBetween",
    "toBuffer",
    "trim",
    "truncate",
    "unescapeByString",
    "unescapeMdCode"
