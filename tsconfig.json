{
  "compilerOptions": {
    "allowJs": false,
    "declaration": true,
    "esModuleInterop": true,
    "lib": [
      "esnext",
      "dom"
    ],
    "types": [
      "jest"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noImplicitAny": false,
    "noUncheckedIndexedAccess": false,
    "noUnusedParameters": false,
    "noImplicitOverride": true,
    "forceConsistentCasingInFileNames": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "rootDir": ".",
    "outDir": "dist",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "strict": true,
    "verbatimModuleSyntax": true,
    "target": "esnext",
    "paths": {
      "razomy": [
        "./razomy/index.ts"
      ],
      "@razomy/*": [
        "./razomy/*/index.ts"
      ]
    }
  },
  "exclude": [
    "**/node_modules",
    "**/dist",
    "**/coverage",
    "./razomy/nuxt",
    "./razomy/vue",
    "./razomy/vue-resource",
    "./razomy/rala-vue"
  ],
  "references": [
    {
      "path": "./razomy/nuxt/tsconfig.json"
    }
  ]
}
