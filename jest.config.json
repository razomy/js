{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "verbose": false,
  "roots": ["razomy"],
  "moduleNameMapper": {
    "^@razomy/(.*)/node": "<rootDir>/razomy/$1/index.node",
    "^@razomy/(.*)": "<rootDir>/razomy/$1"
  },
  "modulePathIgnorePatterns": ["/dist/"],
  "transform": {
    "^.+\\.tsx?$": [
      "ts-jest",
      {
        "tsconfig": "./tsconfig.spec.json"
      }
    ]
  }
}
